{
    "layer": "top",
    "position": "top",
    "reload_style_on_change": true,
    "spacing": 10,
    "modules-center": [
        "custom/notification",
        "clock",
        "custom/pacman",
        "tray"
    ],
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-right": [
        "group/expand",
        "pulseaudio",
